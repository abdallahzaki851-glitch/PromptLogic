rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Global Settings (Allow public read for initial setup)
    match /settings/global {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
